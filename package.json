{
  "name": "smart-alloy-selector",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "jest",
    "lint": "next lint",
    "fetch-mp": "node --env-file=.env.local scripts/fetch-mp.mjs",
    "fetch-mp-materials": "node --env-file=.env.local --import tsx scripts/fetch_mp_materials.ts",
    "process-mp": "node --env-file=.env.local scripts/process-mp.mjs",
    "update-db": "npm run fetch-mp && npm run process-mp",
    "update-db-mp": "npm run fetch-mp && npm run process-mp",
    "scrape:all": "node --env-file=.env.local scripts/scrape/run-all.mjs",
    "assemble-db": "node --env-file=.env.local scripts/assemble-db.mjs",
    "build-db": "npm run fetch-mp && npm run scrape:all && npm run assemble-db",
    "export-csv": "node --import tsx scripts/export-csv.mjs",
    "eval:recommend": "node scripts/evals/run-recommendation-eval.mjs",
    "eval:predict": "node scripts/evals/run-predictor-eval.mjs",
    "eval:full": "node scripts/evals/run-full-eval.mjs"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "@google/generative-ai": "0.24.1",
    "@radix-ui/react-dialog": "1.1.15",
    "@xenova/transformers": "^2.17.2",
    "clsx": "2.1.1",
    "lucide-react": "1.8.0",
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "3.8.1",
    "tailwind-merge": "3.5.0"
  },
  "devDependencies": {
    "@types/node": "20.19.39",
    "@types/jest": "^30.0.0",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "autoprefixer": "10.4.27",
    "axios": "^1.15.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.35",
    "jest": "^30.2.0",
    "playwright": "^1.59.1",
    "postcss": "8.5.9",
    "tailwindcss": "3.4.19",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  }
}
